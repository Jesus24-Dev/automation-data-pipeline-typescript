{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "moduleResolution": "node",

    "target": "es2020",
    "types": ["node", "jest"],

    "sourceMap": true,
    "declaration": true,

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true
  },
  "include": ["src", "tests"]
}